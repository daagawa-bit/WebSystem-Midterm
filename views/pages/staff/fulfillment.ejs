<%- include('../../staffpartials/head') %>
<%- include('../../staffpartials/sidebar') %>

<main class="ml-60 flex-1 flex flex-col min-h-screen bg-slate-50 overflow-hidden">
    <%- include('../../partials/header') %>

    <div class="p-6 overflow-y-auto no-sb">
        <!-- Header Section -->
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-2xl font-black text-slate-800 tracking-tighter mt-3">Logistics <span class="text-pharma-red">Fulfillment</span></h1>
                <p class="text-[9px] font-black text-slate-400 uppercase tracking-[2px] mt-3">Picking, Packing & Batch Verification Terminal</p>
            </div>
            <div class="flex gap-2">
                <span class="px-3 py-1 bg-amber-100 text-amber-600 text-[10px] font-black rounded-full uppercase animate-pulse">
                    🚚 <%= orders.length %> Shipments Pending
                </span>
            </div>
        </div>

        <!-- FULFILLMENT GRID -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% orders.forEach(order => { %>
                <div class="bg-white rounded-[2rem] shadow-sm border border-slate-100 overflow-hidden flex flex-col group hover:shadow-xl transition-all">
                    <!-- Card Top -->
                    <div class="p-6 border-b border-slate-50 bg-white">
                        <div class="flex justify-between items-start mb-4">
                            <span class="text-[10px] font-black text-slate-300 font-mono tracking-widest">#<%= order.id %></span>
                            <span class="px-2 py-1 bg-slate-100 text-slate-500 text-[8px] font-black rounded uppercase">
                                <%= order.delivery %>
                            </span>
                        </div>
                        <h4 class="text-base font-black text-slate-800 leading-tight">🏢 <%= order.client %></h4>
                        <p class="text-[9px] text-slate-400 font-bold uppercase mt-1">Requested: <%= order.date %></p>
                    </div>

                    <!-- Medical Packing Checklist (Smart Feature) -->
                    <div class="p-6 flex-1 bg-slate-50/50">
                        <div class="mb-4">
                            <span class="text-[8px] font-black text-slate-400 uppercase tracking-widest block mb-3">Picking Checklist</span>
                            <div class="space-y-2">
                                <label class="flex items-center gap-3 bg-white p-3 rounded-xl border border-slate-100 cursor-pointer">
                                    <input type="checkbox" class="w-3 h-3 accent-pharma-red" checked>
                                    <span class="text-[10px] font-bold text-slate-600 uppercase">Supplies Verified</span>
                                </label>
                                <div class="bg-pharma-red-pale/30 p-3 rounded-xl border border-pharma-red/10">
                                    <span class="text-[8px] font-black text-pharma-red uppercase block">Assigned Batch</span>
                                    <span class="text-[11px] font-black text-slate-700 font-mono"><%= order.batchNo %></span>
                                </div>
                            </div>
                        </div>

                        <!-- Finance Insight for Staff -->
                        <div class="mt-4 flex justify-between items-center">
                            <span class="text-[10px] font-bold text-slate-400">Total Value:</span>
                            <span class="text-[11px] font-black text-slate-800">₱<%= order.total.toLocaleString() %></span>
                        </div>
                    </div>

                    <!-- Action Button -->
                    <div class="p-4 bg-white border-t border-slate-50">
                        <form action="/staff/fulfillment/update-status/<%= order.id %>" method="POST">
                            <button type="submit" class="w-full py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all
                                <%= order.delivery === 'Pending' ? 'bg-red-400 text-white' : 'bg-red-700 text-white' %> shadow-lg">
                                <% if(order.delivery === 'Pending') { %>
                                    Confirm Packing Complete
                                <% } else { %>
                                    Ready for Dispatch
                                <% } %>
                            </button>
                        </form>
                    </div>
                </div>
            <% }) %>

            <!-- Empty State -->
            <% if(orders.length === 0) { %>
                <div class="col-span-3 py-20 text-center opacity-30">
                    <span class="text-6xl block mb-4">📦</span>
                    <p class="font-black text-xs uppercase tracking-widest">No orders awaiting fulfillment</p>
                </div>
            <% } %>
        </div>
    </div>
    <%- include('../../staffpartials/footer') %>
</main>