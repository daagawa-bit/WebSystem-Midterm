<%- include('../../staffpartials/head') %>
<%- include('../../staffpartials/sidebar') %>

<main class="ml-60 flex-1 flex flex-col min-h-screen bg-slate-50 overflow-hidden">
    <%- include('../../partials/header') %>

    <div class="p-6 overflow-y-auto no-sb">
        <!-- HEADER -->
        <div class="flex justify-between items-center mb-6">
            <div>
                <h1 class="text-2xl font-black text-slate-800 tracking-tighter mt-3">Operations <span class="text-pharma-red">Terminal</span></h1>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-[2px] mt-3">Real-time Duty Dashboard & Inventory Health</p>
            </div>
            <div class="flex gap-3">
                <a href="/staff/inventory" class="px-4 py-2 bg-white border border-slate-200 text-slate-500 rounded-xl text-[10px] font-black uppercase hover:border-pharma-red transition-all">Stock Look-up</a>
                <a href="/staff/pos" class="px-4 py-2 bg-white border border-slate-200 text-slate-500 rounded-xl text-[10px] font-black uppercase hover:border-pharma-red transition-all">Open Register</a>
            </div>
        </div>

        <div class="grid grid-cols-4 gap-4 mb-6">
            <div class="bg-white p-5 rounded-[1.5rem] border border-slate-100 shadow-sm">
                <span class="text-[8px] font-black text-slate-400 uppercase tracking-widest block mb-1">Stock Alerts</span>
                <h2 class="text-xl font-black text-pharma-red"><%= stats.lowStock %> Items</h2>
            </div>
            <div class="bg-white p-5 rounded-[1.5rem] border border-slate-100 shadow-sm">
                <span class="text-[8px] font-black text-slate-400 uppercase tracking-widest block mb-1">To Fulfill</span>
                <h2 class="text-xl font-black text-slate-800"><%= stats.pendingOrders %> Orders</h2>
            </div>
            <div class="bg-white p-5 rounded-[1.5rem] border border-slate-100 shadow-sm">
                <span class="text-[8px] font-black text-slate-400 uppercase tracking-widest block mb-1">Sales Today</span>
                <h2 class="text-xl font-black text-slate-800"><%= stats.itemsHandled %> Transactions</h2>
            </div>
            <div class="bg-white p-5 rounded-[1.5rem] border border-slate-100 shadow-sm">
                <span class="text-[8px] font-black text-slate-400 uppercase tracking-widest block mb-1">Duty Efficiency</span>
                <h2 class="text-xl font-black text-slate-800"><%= stats.efficiency %></h2>
            </div>
        </div>

        <div class="grid grid-cols-12 gap-6 items-start">
            
            <!-- LEFT: OPERATION TASKS -->
            <div class="col-span-4 space-y-3">
                <h3 class="text-[9px] font-black text-slate-400 uppercase tracking-[2px] ml-2 mb-4">Assigned Tasks</h3>
                <div class="bg-white p-5 rounded-[2rem] border-l-4 border-l-pharma-red shadow-sm group hover:translate-x-1 transition-transform">
                    <div class="flex justify-between">
                        <strong class="text-xs font-black text-slate-700">INVENTORY COUNT</strong>
                        <span class="text-[8px] font-bold text-pharma-red italic">URGENT</span>
                    </div>
                    <p class="text-[10px] text-slate-400 mt-1">Verify batch #BN-5466 for LGU Iriga delivery.</p>
                </div>
                <div class="bg-white p-5 rounded-[2rem] border-l-4 border-l-slate-200 shadow-sm">
                    <strong class="text-xs font-black text-slate-700">BAY CLEANUP</strong>
                    <p class="text-[10px] text-slate-400 mt-1">Maintenance of the Diagnostic equipment zone.</p>
                </div>
            </div>

            <!-- CENTER: LIVE INVENTORY LOGISTICS -->
            <div class="col-span-5 bg-white rounded-[2rem] p-6 border border-slate-100 shadow-sm">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-[9px] font-black text-slate-400 uppercase tracking-[2px]">Inventory Watch</h3>
                    <span class="text-[8px] font-bold text-slate-300">CRITICAL ITEMS</span>
                </div>
                <div class="space-y-3">
                    <% if(inventory.length > 0) { %>
                        <% inventory.forEach(item => { %>
                            <div class="flex justify-between items-center p-4 bg-red-50/50 rounded-2xl border border-red-100">
                                <div>
                                    <p class="text-[10px] font-black text-slate-700 uppercase"><%= item.name %></p>
                                    <p class="text-[8px] text-pharma-red font-bold italic"><%= item.qty %> Units Remaining</p>
                                </div>
                                <span class="text-xs animate-pulse">🚨</span>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p class="text-[10px] text-slate-400 italic">No inventory alerts found.</p>
                    <% } %>
                </div>
            </div>

            <!-- RIGHT: RECENT POS LOG -->
            <div class="col-span-3 space-y-4">
                <h3 class="text-[9px] font-black text-slate-400 uppercase tracking-[2px] ml-2 mb-4">Counter Activity</h3>
                <div class="bg-slate-900 rounded-[2rem] p-6 text-white shadow-2xl">
                    <% if(recentSales.length > 0) { %>
                        <% recentSales.forEach(sale => { %>
                            <div class="mb-4 pb-4 border-b border-white/5 last:border-0 last:mb-0">
                                <div class="flex justify-between text-[11px]">
                                    <span class="font-bold text-white/90"><%= sale.id %></span>
                                    <span class="text-pharma-red font-black">₱<%= (sale.total || 0).toLocaleString() %></span>
                                </div>
                                <p class="text-[8px] text-white/40 mt-1 uppercase font-bold tracking-widest"><%= sale.time %> | <%= sale.method %></p>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p class="text-[9px] text-white/20 italic">No transactions recorded today.</p>
                    <% } %>
                </div>
            </div>

        </div>
    </div>
    <%- include('../../staffpartials/footer') %>
</main>

