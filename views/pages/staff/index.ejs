<%- include('../../staffpartials/head') %>
<%- include('../../staffpartials/sidebar') %>

<main class="staff-main-area">
    <%- include('../../staffpartials/header') %>

    <div class="content">
        <div class="page-header">
            <div>
                <h1 style="font-family: 'Nunito', sans-serif; font-weight: 900;">Operations <span style="color: var(--red);">Terminal</span></h1>
                <p class="staff-label">Personal Dashboard & Duty Summary</p>
            </div>
            <div style="display: flex; gap: 10px;">
                <a href="/staff/inventory" class="btn btn-primary" style="font-size: 0.7rem; padding: 10px 20px;">⚡ Quick Look-up</a>
            </div>
        </div>

        <!-- NEW: Performance Metrics -->
        <div class="kpi-row" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; margin-bottom: 25px;">
            <div class="kpi-card white">
                <div class="kpi-value">3</div>
                <div class="kpi-label">Tasks Pending</div>
            </div>
            <div class="kpi-card white">
                <div class="kpi-value" style="color: var(--red);">85%</div>
                <div class="kpi-label">Duty Efficiency</div>
            </div>
            <div class="kpi-card white">
                <div class="kpi-value">12</div>
                <div class="kpi-label">Items Handled</div>
            </div>
            <div class="kpi-card white">
                <div class="kpi-value">Active</div>
                <div class="kpi-label">Shift Status</div>
            </div>
        </div>

        <div class="dashboard-grid" style="grid-template-columns: 1.5fr 1fr;">
            
            <!-- Daily Task Management -->
            <div class="col-span-1">
                <span class="staff-label">Operation Tasks</span>
                <div class="staff-task-card urgent">
                    <strong style="font-size: 0.8rem;">Verify Batch B-2025</strong>
                    <p style="font-size: 0.7rem; color: #666;">Check expiry dates on all Paracetamol stocks.</p>
                </div>
                <div class="staff-task-card">
                    <strong style="font-size: 0.8rem;">Restock Bay 4</strong>
                    <p style="font-size: 0.7rem; color: #666;">Move 50 units of Face Masks to front shelf.</p>
                </div>
            </div>

            <!-- NEW: Staff Activity Log -->
            <div class="col-span-1">
                <div class="table-card">
                    <div class="table-header"><h2>Recent Activity</h2></div>
                    <div style="padding: 15px; display: flex; flex-direction: column; gap: 12px;">
                        <div style="font-size: 0.7rem; padding-bottom: 8px; border-bottom: 1px solid #f1f1f1;">
                            <span style="color: var(--red); font-weight: 800;">10:30 AM</span> - Searched for "Nebulizer"
                        </div>
                        <div style="font-size: 0.7rem; padding-bottom: 8px; border-bottom: 1px solid #f1f1f1;">
                            <span style="color: var(--red); font-weight: 800;">09:15 AM</span> - Answered Client Query #102
                        </div>
                        <div style="font-size: 0.7rem;">
                            <span style="color: var(--red); font-weight: 800;">08:00 AM</span> - Logged into Terminal
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
    <%- include('../../staffpartials/footer') %>
</main>