<%- include('../../partials/head') %>
<%- include('../../partials/sidebar') %>

<div class="main-area">
    <%- include('../../partials/header') %>

    <div class="content p-8">
        <div class="page-header mb-8">
            <div>
                <h1 class="text-3xl font-black text-slate-800 tracking-tight italic">Staff <span
                        class="text-pharma-red">Management</span></h1>
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-[3px]">Internal Access Control System
                </p>
            </div>
            <!-- FIX: Button now calls resetUserForm for smooth scroll + pulse -->
            <button class="btn btn-primary shadow-xl" onclick="resetUserForm()">＋ Create New User</button>
        </div>

        <!-- KPI Summary (Smarter Stats) -->
        <div class="intel-grid mb-10">
            <div class="intel-card">
                <span class="kpi-label-sm">Total Accounts</span>
                <h2><%= users.length %></h2>
            </div>
            <div class="intel-card">
                <span class="kpi-label-sm">Administrators</span>
                <h2 class="text-pharma-red"><%= users.filter(u=>u.role==='Admin').length %></h2>
            </div>
            <div class="intel-card">
                <span class="kpi-label-sm">Staff Members</span>
                <h2><%= users.filter(u=>u.role==='Staff').length %></h2>
            </div>
        </div>

        <!-- Table Card -->
        <div class="table-card bg-white rounded-[2rem] border-0 shadow-sm overflow-hidden mb-12">
            <div class="table-header p-6 border-b border-gray-50 flex justify-between items-center bg-white">
                <h2 class="font-black text-xs uppercase tracking-widest text-slate-500">Combined Access Registry</h2>
                <!-- Smarter Feature: Quick Search -->
                <input type="text" id="userSearch" onkeyup="filterUsers()" placeholder="Search name or email..."
                    class="text-[11px] p-2 border border-slate-100 rounded-xl outline-none focus:border-pharma-red">
            </div>
            <table id="userTable" class="w-full text-left border-collapse">
                <thead class="bg-slate-50 text-slate-400 text-[10px] font-black uppercase tracking-widest">
                    <tr>
                        <th class="p-6">User Identity</th>
                        <th class="p-6">Account Role</th>
                        <th class="p-6">Security Status</th>
                        <th class="p-6 text-center">Management</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    <% users.forEach(user => { %>
                    <tr class="hover:bg-pharma-red-pale transition-colors group">
                        <td class="p-6">
                            <div class="font-bold text-slate-700 text-sm">👤 <%= user.name %></div>
                            <div class="text-[10px] text-slate-400 font-medium"><%= user.email %></div>
                        </td>
                        <td class="p-6">
                            <span
                                class="px-3 py-1 rounded-lg text-[9px] font-black uppercase <%= user.role==='Admin'?'bg-red-100 text-red-600':'bg-blue-100 text-blue-600' %>">
                                <%= user.role %>
                            </span>
                        </td>
                        <td class="p-6">
                            <span
                                class="px-3 py-1 bg-emerald-100 text-emerald-600 text-[9px] font-black rounded-full uppercase">Active</span>
                        </td>
                        <td class="p-6 text-center">
                            <div class="flex justify-center gap-2">
                                <button class="btn btn-outline btn-sm"
                                    onclick='editUser(`<%- JSON.stringify(user) %>`)'>Edit</button>
                                <a href="/users/delete/<%= user.email %>" class="btn btn-outline btn-sm text-pharma-red"
                                    style="border-color:var(--red)"
                                    onclick="return confirm('Permanently remove access?')">Delete</a>
                            </div>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <!-- THE SMART FORM CARD -->
        <div class="form-card bg-white rounded-[2.5rem] p-10 shadow-2xl border-0" id="userFormCard">
            <div class="form-title mb-8 border-b border-slate-100 pb-6">
                <h2 class="text-2xl font-black text-slate-800">➕ Register New User</h2>
                <!-- Mode Badge (Smarter UI) -->
                <span id="formModeBadge"
                    class="px-3 py-1 bg-pharma-red-pale text-pharma-red text-[10px] font-black rounded-full uppercase italic">
                    Registration Mode
                </span>
            </div>

            <form method="POST" action="/users/add">
                <div class="grid grid-cols-2 gap-6 mb-8">
                    <div class="form-group flex flex-col gap-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-[2px] ml-1">Full Legal
                            Name</label>
                        <input type="text" name="name" required placeholder="e.g. Daisyree Dela Cruz"
                            class="p-4 bg-slate-50 border-0 rounded-2xl outline-none focus:ring-2 focus:ring-pharma-red/20 transition-all font-medium" />
                    </div>
                    <div class="form-group flex flex-col gap-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-[2px] ml-1"
                            style="margin-top: 15px;">Official
                            Email Address</label>
                        <input type="email" name="email" required placeholder="name@pharmed.com"
                            class="p-4 bg-slate-50 border-0 rounded-2xl outline-none focus:ring-2 focus:ring-pharma-red/20 transition-all font-medium" />
                    </div>
                    <div class="form-group flex flex-col gap-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-[2px] ml-1"
                            style="margin-top: 15px;">Assigned
                            Password</label>
                        <input type="password" name="password" required placeholder="••••••••"
                            class="p-4 bg-slate-50 border-0 rounded-2xl outline-none focus:ring-2 focus:ring-pharma-red/20 transition-all font-medium" />
                    </div>
                    <div class="form-group flex flex-col gap-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-[2px] ml-1"
                            style="margin-top: 15px;">Access
                            Privileges</label>
                        <select name="role"
                            class="p-4 bg-slate-50 border-0 rounded-2xl outline-none focus:ring-2 focus:ring-pharma-red/20 transition-all font-black text-xs text-slate-500"
                            style="margin-bottom: 15px;">
                            <option value="Staff">Standard Staff Member</option>
                            <option value="Admin">System Administrator</option>
                        </select>
                    </div>
                </div>

                <div class="d-flex gap-3 pt-4 border-top border-light">
                    <button type="submit" id="userSubmitBtn" class="flex-fill btn fw-bold text-uppercase py-3 rounded-4 shadow-lg 
               bg-danger text-white btn-lg hover:bg-danger">
                        Save Account
                    </button>
                    <button type="button" onclick="resetUserForm()" class="flex-fill btn fw-bold text-uppercase py-3 rounded-4 shadow-sm 
               border border-danger text-danger btn-lg hover:bg-danger hover:text-white">
                        Clear
                    </button>
                </div>
            </form>
        </div>
    </div>
    </main>

    <!-- JavaScript Integration -->
    <script>
        function highlightForm() {
            const container = document.getElementById('userFormCard');
            container.scrollIntoView({
                behavior: 'smooth',
                block: 'center'
            });
            container.classList.add('form-focus-pulse');
            setTimeout(() => {
                container.classList.remove('form-focus-pulse');
            }, 1500);
        }

        function editUser(jsonStr) {
            const user = JSON.parse(jsonStr);
            const form = document.querySelector('#userFormCard form');
            const title = document.querySelector('#userFormCard h2');
            const submitBtn = document.getElementById('userSubmitBtn');
            const modeBadge = document.getElementById('formModeBadge');

            form.action = '/users/edit/' + user.email;
            form.querySelector('[name="name"]').value = user.name;
            form.querySelector('[name="email"]').value = user.email;
            form.querySelector('[name="email"]').readOnly = true;
            form.querySelector('[name="password"]').value = user.password;
            form.querySelector('[name="role"]').value = user.role;

            title.innerHTML = "✏️ Modify Account: " + user.name;
            modeBadge.innerHTML = "Modification Mode";
            modeBadge.className =
                "px-3 py-1 bg-blue-100 text-blue-600 text-[9px] font-black rounded-full uppercase italic";
            submitBtn.innerHTML = "Update User";
            highlightForm();
        }

        function resetUserForm() {
            const form = document.querySelector('#userFormCard form');
            const title = document.querySelector('#userFormCard h2');
            const submitBtn = document.getElementById('userSubmitBtn');
            const modeBadge = document.getElementById('formModeBadge');

            form.action = '/users/add';
            form.reset();
            form.querySelector('[name="email"]').readOnly = false;
            title.innerHTML = "➕ User Provisioning";
            modeBadge.innerHTML = "Registration Mode";
            modeBadge.className =
                "px-3 py-1 bg-pharma-red-pale text-pharma-red text-[10px] font-black rounded-full uppercase italic";
            submitBtn.innerHTML = "Save Record";
            highlightForm();
        }

        function filterUsers() {
            const q = document.getElementById('userSearch').value.toLowerCase();
            document.querySelectorAll('#userTable tbody tr').forEach(row => {
                row.style.display = row.innerText.toLowerCase().includes(q) ? '' : 'none';
            });
        }
    </script>

    <%- include('../../partials/footer') %>