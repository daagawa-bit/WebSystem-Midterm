<%- include('../../partials/head') %>
<%- include('../../partials/sidebar') %>

<div class="main-area">
    <%- include('../../partials/header') %>

    <div class="content">
        <!-- WELCOME MESSAGE FOR ADMIN -->
        <div class="mb-8">
            <h2 style="font-family: 'Nunito', sans-serif; font-weight: 900; font-size: 1.6rem; color: var(--gray-800);">
                Welcome back, <%= adminName %>! 👋
            </h2>
            <p style="font-size: 0.75rem; color: var(--gray-400); font-weight: 600; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 20px;">
                Operations & Management Command Center: Robin Rose Trading
            </p>
        </div>

        <!-- KPI Row (Now aligned with Active/Completed statuses) -->
        <div class="kpi-row">
            <div class="kpi-card">
                <div class="kpi-value"><%= data.kpi.salesPending %></div>
                <div class="kpi-label">Sales Pending</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-value"><%= data.kpi.inTransit %></div>
                <div class="kpi-label">In Transit</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-value"><%= data.kpi.delivered %></div>
                <div class="kpi-label">Delivered</div>
            </div>
            <div class="inventory-summary-card">
                <button class="inv-btn" onclick="window.location='/inventory'">Inventory Summary</button>
                <div class="inv-row"><span class="label">Quantity Onhand</span><span class="value"><%= data.kpi.qtyOnHand %></span></div>
                <div class="inv-row"><span class="label">Qty To Be Received</span><span class="value"><%= data.kpi.qtyToReceive %></span></div>
            </div>
        </div>

        <div class="dashboard-grid">
            <div class="dash-card">
                <h3>Product Details</h3>
                <div class="product-detail-row"><span>All Items</span><span class="pd-val"><%= data.productDetails.allItems %></span></div>
                <div class="product-detail-row"><span>Low Stock</span><span class="pd-val warn text-red"><%= data.productDetails.lowStock %></span></div>
                <div class="product-detail-row"><span>Expired</span><span class="pd-val warn"><%= data.productDetails.expired %></span></div>
                <div class="product-detail-row"><span>Suppliers</span><span class="pd-val">12</span></div>
                <a href="/inventory" class="btn btn-outline btn-sm mt-4" style="display:inline-flex">View Inventory →</a>
            </div>

            <div class="dash-card">
                <h3>Revenue Mix</h3>
                <div class="donut-wrap">
                    <div class="donut" style="background: conic-gradient(var(--red) 0% <%= data.sales.deliveryToClient %>%, #FFC5CC <%= data.sales.deliveryToClient %>% 100%);">
                        <div class="donut-inner"></div>
                    </div>
                    <div class="donut-legend">
                        <div class="legend-item"><div class="legend-dot" style="background:var(--red)"></div><span>Institutional (<%= data.sales.deliveryToClient %>%)</span></div>
                        <div class="legend-item"><div class="legend-dot" style="background:#FFC5CC"></div><span>Walk-in (<%= data.sales.walkInCustomer %>%)</span></div>
                    </div>
                </div>
            </div>

            <div class="dash-card">
                <h3>Top Partners & Products</h3>
                <div class="top-items mb-4" style="margin-bottom: 10px;">
                    <% data.topClients.forEach(c => { %>
                        <!-- RESTORED: 🏢 Icon -->
                        <div class="top-item"><span>🏢 <%= c %></span><span class="badge badge-success">Partner</span></div>
                    <% }) %>
                </div>
                <div class="top-items">
                    <% data.topProducts.forEach(p => { %>
                        <!-- RESTORED: 💊 Icon -->
                        <div class="top-item"><span>💊 <%= p %></span><span class="text-red font-bold">⭐ Top</span></div>
                    <% }) %>
                </div>
            </div>
        </div>

        <div class="dashboard-grid mt-4">
            <div class="dash-card">
                <h3 style="display:flex; justify-content:space-between;">Financial Health <span class="badge badge-info">Monthly</span></h3>
                <div style="margin-top:20px;">
                    <p class="text-micro">Target Sales: ₱<%= data.financials.monthlyTarget.toLocaleString() %></p>
                    <div style="height:8px; background:#f1f1f1; border-radius:10px; margin:10px 0; overflow:hidden;">
                        <div style="width:<%= data.financials.progress %>%; height:100%; background:var(--red);"></div>
                    </div>
                    <div class="flex justify-between mt-2">
                        <span style="font-size:0.65rem; color:#999;">Current: ₱<%= data.sales.totalValue.toLocaleString() %></span>
                        <span style="font-size:0.65rem; font-weight:900; color:var(--red);"><%= data.financials.progress %>%</span>
                    </div>
                </div>
            </div>

            <div class="dash-card">
                <h3 style="color:var(--red);">⚠️ Stock Exhaustion Forecast</h3>
                <div class="top-items mt-4">
                    <% if(data.forecast.length > 0) { %>
                        <% data.forecast.forEach(f => { %>
                            <div class="top-item">
                                <span><%= f.name %></span>
                                <strong class="text-red italic"><%= f.daysRemaining %> days left</strong>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p style="font-size:0.7rem; color:#999;">All stocks verified healthy.</p>
                    <% } %>
                </div>
            </div>

            <div class="dash-card" style="background:var(--gray-800); color:white; border:none;">
                <h3 style="color:white; opacity:0.6;">Operational Status</h3>
                <div class="product-detail-row" style="border-color:rgba(255,255,255,0.1);"><span style="color:white;">Active Staff</span><span class="pd-val"><%= data.activeStaff %></span></div>
                <div class="product-detail-row" style="border-color:rgba(255,255,255,0.1);"><span style="color:white;">Server Health</span><span class="pd-val" style="color:#10b981;">99.9%</span></div>
                <div class="product-detail-row" style="border-color:rgba(255,255,255,0.1); border:none;"><span style="color:white;">Last Sync</span><span class="pd-val">Just Now</span></div>
            </div>
        </div>

        <div class="table-card mt-6" style="margin-top:20px;">
            <div class="table-header">
                <h2>Real-time Activity Log</h2><span class="badge badge-info">Live</span>
            </div>
            <table>
                <thead><tr><th>Context</th><th>Event Description</th><th>Status</th></tr></thead>
                <tbody>
                    <% data.recentActivity.forEach(a => { %>
                        <tr>
                            <td><span style="color:var(--gray-400); font-size:0.75rem;"><%= a.time %></span></td>
                            <td><strong><%= a.event %></strong></td>
                            <td><span class="badge badge-<%= a.type %>"><%= a.type.toUpperCase() %></span></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<%- include('../../partials/footer') %>