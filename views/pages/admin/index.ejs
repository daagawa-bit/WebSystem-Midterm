<%- include('../../partials/head') %>
    <%- include('../../partials/sidebar') %>

        <div class="main-area">
            <%- include('../../partials/header') %>

                <div class="content">

                    <!-- KPI Row -->
                    <div class="kpi-row">
                        <div class="kpi-card">
                            <div class="kpi-value">
                                <%= data.kpi.salesPending %>
                            </div>
                            <div class="kpi-label">Sales Pending</div>
                        </div>
                        <div class="kpi-card">
                            <div class="kpi-value">
                                <%= data.kpi.inTransit %>
                            </div>
                            <div class="kpi-label">In Transit</div>
                        </div>
                        <div class="kpi-card">
                            <div class="kpi-value">
                                <%= data.kpi.delivered %>
                            </div>
                            <div class="kpi-label">Delivered</div>
                        </div>
                        <div class="inventory-summary-card">
                            <button class="inv-btn" onclick="window.location='/inventory'">Inventory Summary</button>
                            <div class="inv-row">
                                <span class="label">Quantity Onhand</span>
                                <span class="value">
                                    <%= data.kpi.qtyOnHand %>
                                </span>
                            </div>
                            <div class="inv-row">
                                <span class="label">Qty To Be Received</span>
                                <span class="value">
                                    <%= data.kpi.qtyToReceive %>
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Dashboard Grid -->
                    <div class="dashboard-grid">

                        <!-- Product Details -->
                        <div class="dash-card">
                            <h3>Product Details</h3>
                            <div class="product-detail-row"><span>All Items</span><span class="pd-val">
                                    <%= data.productDetails.allItems %>
                                </span></div>
                            <div class="product-detail-row"><span>Low Stock</span><span class="pd-val warn">
                                    <%= data.productDetails.lowStock %>
                                </span></div>
                            <div class="product-detail-row"><span>Expired</span><span class="pd-val">
                                    <%= data.productDetails.expired %>
                                </span></div>
                            <div class="product-detail-row"><span>Products</span><span class="pd-val">
                                    <%= data.productDetails.products %>
                                </span></div>
                            <a href="/inventory" class="btn btn-outline btn-sm mt-4" style="display:inline-flex">View
                                Inventory →</a>
                        </div>

                        <!-- Sales Mix Donut -->
                        <div class="dash-card">
                            <h3>Sales Mix</h3>
                            <div class="donut-wrap">
                                <div class="donut"
                                    style="background: conic-gradient(var(--red) 0% '<%= data.sales.deliveryToClient %>%', #FFC5CC '<%= data.sales.deliveryToClient %>%' 100%);">
                                    <div class="donut-inner"></div>
                                </div>
                                <div class="donut-legend">
                                    <div class="legend-item">
                                        <div class="legend-dot" style="background:var(--red)"></div>
                                        <span>Delivery to Client (<%= data.sales.deliveryToClient %>%)</span>
                                    </div>
                                    <div class="legend-item">
                                        <div class="legend-dot" style="background:#FFC5CC"></div>
                                        <span>Walk-in Customer (<%= data.sales.walkInCustomer %>%)</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Top Clients & Products -->
                        <div class="dash-card">
                            <h3>Top Institutional Clients</h3>
                            <div class="top-items mb-4">
                                <% data.topClients.forEach(c=> { %>
                                    <div class="top-item"><span>🏢 <%= c %></span><span
                                            class="badge badge-success">Active</span></div>
                                    <% }) %>
                            </div>
                            <h3 class="mt-4">Top Sales Products</h3>
                            <div class="top-items">
                                <% data.topProducts.forEach(p=> { %>
                                    <div class="top-item"><span>💊 <%= p %></span><span class="text-red font-bold">⭐
                                            Top</span></div>
                                    <% }) %>
                            </div>
                        </div>

                    </div>

                    <!-- Recent Activity Table -->
                    <div class="table-card mt-60">
                        <div class="table-header">
                            <h2>Recent Activity Log</h2>
                            <span class="badge badge-info">Real-time</span>
                        </div>
                        <table>
                            <thead>
                                <tr>
                                    <th>Time</th>
                                    <th>Event Description</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% data.recentActivity.forEach(a=> { %>
                                    <tr>
                                        <td><span style="color:var(--gray-400); font-size:0.75rem;">
                                                <%= a.time %>
                                            </span></td>
                                        <td>
                                            <%= a.event %>
                                        </td>
                                        <td>
                                            <span class="badge badge-<%= a.type %>">
                                                <%= a.type.toUpperCase() %>
                                            </span>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>

                </div>
        </div>

        <%- include('../../partials/footer') %>