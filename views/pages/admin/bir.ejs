<%- include('../../partials/head') %>
<%- include('../../partials/sidebar') %>

<!-- 1. ADDED PDF LIBRARY (CDN) -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

<div class="main-area">
    <%- include('../../partials/header') %>

    <div class="content" id="ledger-content">
        <div class="page-header">
            <div>
                <h1 class="text-3xl font-black text-slate-800 tracking-tighter">BIR <span class="text-pharma-red">Compliance</span></h1>
                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Official Receipts & Tax Reporting</p>
            </div>
            <div class="flex gap-3">
                <!-- 2. UPDATED TO CALL PDF FUNCTION -->
                <button class="btn btn-outline" onclick="exportLedgerPDF()">⬇ Export Ledger PDF</button>
            </div>
        </div>

        <div class="alert-compliance">
            <span>⚠️</span>
            <span>BIR RR 11-2025 compliance: Ensure all OR numbers are sequential and TIN is printed on every receipt.</span>
        </div>

        <!-- Summary KPIs -->
        <div class="kpi-row" style="display: grid; grid-template-columns:repeat(4,1fr); margin-bottom:24px; gap: 20px;">
            <div class="kpi-card white">
                <div class="kpi-value text-slate-800">₱<%= Number(totals.gross).toLocaleString() %></div>
                <div class="kpi-label">Gross Sales</div>
            </div>
            <div class="kpi-card white">
                <div class="kpi-value text-slate-800">₱<%= Number(totals.vatable).toLocaleString() %></div>
                <div class="kpi-label">VATable Sales</div>
            </div>
            <div class="kpi-card white">
                <div class="kpi-value text-pharma-red">₱<%= Number(totals.vat).toLocaleString() %></div>
                <div class="kpi-label text-pharma-red">Output VAT (12%)</div>
            </div>
            <div class="kpi-card white">
                <div class="kpi-value text-slate-800"><%= birRecords.length %></div>
                <div class="kpi-label">ORs Issued</div>
            </div>
        </div>

        <!-- OR Ledger Table -->
        <div class="table-card">
            <div class="table-header">
                <h2 class="font-black text-sm uppercase tracking-widest text-slate-500">Official Receipt Log</h2>
                <!-- 3. ADDED SEARCH INPUT -->
                <input type="text" id="searchOR" onkeyup="filterLedger()" placeholder="Search OR or Customer..." 
                       style="font-size: 11px; padding: 8px; border: 1px solid #ddd; border-radius: 8px; width: 220px; outline: none;">
            </div>
            <table id="birTable">
                <thead>
                    <tr>
                        <th>OR No.</th>
                        <th>Date</th>
                        <th>Customer</th>
                        <th>Gross Sales</th>
                        <th>VATable Sales</th>
                        <th>VAT (12%)</th>
                        <th>Total</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% birRecords.forEach(function(r){ %>
                        <tr>
                            <td><strong class="text-pharma-red"><%= r.orNo %></strong></td>
                            <td><%= r.date %> <span class="text-[9px] text-slate-300 ml-1"><%= r.time %></span></td>
                            <td class="font-bold text-slate-700"><%= r.customer %></td>
                            <td>₱<%= Number(r.grossSales).toLocaleString() %></td>
                            <td>₱<%= Number(r.vatableSales).toLocaleString(undefined, {minimumFractionDigits: 2}) %></td>
                            <td class="text-pharma-red">₱<%= Number(r.vatAmount).toLocaleString(undefined, {minimumFractionDigits: 2}) %></td>
                            <td><strong class="text-slate-800">₱<%= Number(r.total).toLocaleString() %></strong></td>
                            <td class="text-center">
                                <button class="btn btn-outline btn-sm" onclick="previewOR('<%= r.orNo %>')">
                                    🖨 View OR
                                </button>
                            </td>
                        </tr>
                    <% }) %>

                    <tr class="bir-totals-row">
                        <td colspan="3" style="text-align:right; padding-right:20px; font-weight: 900; font-size: 10px;">MONTHLY AGGREGATE</td>
                        <td>₱<%= Number(totals.gross).toLocaleString() %></td>
                        <td>₱<%= Number(totals.vatable).toLocaleString(undefined, {minimumFractionDigits: 2}) %></td>
                        <td>₱<%= Number(totals.vat).toLocaleString(undefined, {minimumFractionDigits: 2}) %></td>
                        <td>₱<%= Number(totals.gross).toLocaleString() %></td>
                        <td></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- OR MODAL -->
    <div id="orModal" class="or-modal">
        <div id="receipt-paper" class="or-paper">
            <div class="text-center mb-6">
                <h4 class="font-black text-sm">ROBIN ROSE TRADING</h4>
                <p class="text-[10px]">MEDICAL SUPPLY & DIST.</p>
                <p class="text-[10px]">VAT REG TIN: 123-456-789-000</p>
                <p class="mt-2 opacity-20">************************</p>
            </div>

            <div class="space-y-1 mb-6 text-[11px]">
                <div class="flex justify-between"><span>OR NO:</span> <span id="or-num" class="font-bold text-pharma-red"></span></div>
                <div class="flex justify-between"><span>DATE:</span> <span id="or-date"></span></div>
            </div>

            <div class="space-y-1 mb-6 text-[11px] border-y border-dashed border-slate-300 py-4">
                <div class="flex justify-between"><span>VATABLE SALES</span> <span id="or-vat-sales"></span></div>
                <div class="flex justify-between font-bold"><span>VAT (12%)</span> <span id="or-vat-amt"></span></div>
                <div class="flex justify-between font-black text-sm mt-2 pt-2 border-t border-black">
                    <span>GRAND TOTAL</span> <span id="or-total"></span>
                </div>
            </div>

            <div class="text-center text-[9px]">
                <p class="mb-1 font-bold italic uppercase">Partner in Health Care</p>
                <p class="text-slate-400">Valid for Audit Purposes</p>
            </div>

            <div class="flex gap-2 mt-8">
                <button class="flex-1 bg-pharma-red text-white text-[10px] py-3 font-black rounded-lg uppercase" onclick="exportORPDF()">Download PDF</button>
                <button class="flex-1 bg-slate-100 text-slate-500 text-[10px] py-3 font-black rounded-lg uppercase" onclick="closeOR()">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- CRITICAL FIX: REMOVED SINGLE QUOTES AROUND JSON -->
<script>
    window.allSalesData = <%- JSON.stringify(birRecords) %>;
</script>

<script src="/js/bir-logic.js"></script>
<%- include('../../partials/footer') %>