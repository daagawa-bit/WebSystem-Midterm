<%- include('../../partials/head') %>
<%- include('../../partials/sidebar') %>

<div class="main-area">
    <%- include('../../partials/header') %>

    <div class="content p-6">
        <!-- Dashboard Header -->
        <header class="page-header"
            style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; border-bottom: 2px solid #f1f5f9; padding-bottom: 15px;">
            <!-- LEFT SIDE: TITLE -->
            <div>
                <h1 class="text-2xl font-black text-slate-800 tracking-tighter italic">
                    Institutional <span class="text-pharma-red">Pipeline</span>
                </h1>
                <p class="label-micro"
                    style="margin-top: 2px; color: #94a3b8; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px;">
                    Logistics & Audit Control
                </p>
            </div>

            <!-- RIGHT SIDE: SEARCH & ACTIONS -->
            <div class="page-header-actions">
                <!-- THE SMART SEARCH BAR -->
                <div class="search-wrapper-smart">
                    <input type="text" id="salesSearch" onkeyup="filterSales()"
                        placeholder="Search Order ID or Client...">
                </div>

                <!-- Revenue Badge -->
                <div
                    style="background: var(--red); color: white; padding: 10px 18px; border-radius: 12px; font-size: 11px; font-weight: 900; box-shadow: 0 4px 12px rgba(232, 52, 74, 0.2);">
                    ₱<%= totalSales.toLocaleString() %>
                </div>
            </div>
        </header>

        <div class="sales-workspace">
            <!-- LEFT: ORDER LIST -->
            <section class="order-registry">
                <div class="registry-scroll no-sb">
                    <table class="sales-table">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Facility / Batch</th>
                                <th>Financials</th>
                                <th>Logistics</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="salesTableBody">
                            <% salesOrders.forEach(o => { %>
                            <tr onclick='inspectOrder(`<%- JSON.stringify(o) %>`)'
                                class="cursor-pointer hover:bg-red-50/30 transition">
                                <td class="font-mono font-bold text-slate-400">#<%= o.id %></td>
                                <td>
                                    <div class="font-bold text-slate-700"><%= o.client %></div>
                                    <div class="text-[8px] text-pharma-red font-black uppercase">Ref: <%= o.batchNo %>
                                    </div>
                                </td>
                                <td>
                                    <div class="font-black text-slate-800">₱<%= o.total.toLocaleString() %></div>
                                    <div class="text-[9px] text-slate-400 uppercase"><%= o.method %></div>
                                </td>
                                <td>
                                    <% if(o.delivery === 'Pending') { %>
                                    <a href="/sales/update/<%= o.id %>/delivery/In Transit" class="ship-btn">🚚 Ship
                                        Now</a>
                                    <% } else if(o.delivery === 'In Transit') { %>
                                    <a href="/sales/update/<%= o.id %>/delivery/Delivered" class="ship-btn"
                                        style="color:#10b981; border-color:#d1fae5; background:#ecfdf5;">✅ Received?</a>
                                    <% } else { %>
                                    <span
                                        class="text-emerald-500 font-black text-[9px] uppercase italic">Delivered</span>
                                    <% } %>
                                </td>
                                <td><span class="badge <%= o.status==='Active'?'badge-warning':'badge-success' %>"
                                        style="font-size: 8px;"><%= o.status %></span></td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </section>

            <aside class="flex flex-col gap-4">
                <div class="order-audit-panel flex-1">
                    <div class="audit-head">
                        <h2>Order Audit</h2>
                    </div>

                    <div id="audit-placeholder" class="p-12 text-center opacity-30">
                        <p class="text-[10px] font-black uppercase tracking-widest" style="margin-top: 10px;">Select an order to print sales invoice</p>
                    </div>

                    <div id="audit-ui" class="audit-body" style="display:none;">
                        <div class="space-y-2">
                            <div class="audit-row"><span class="audit-label">Reference ID</span> <span id="view-id"
                                    class="audit-val font-mono"></span></div>
                            <div class="audit-row"><span class="audit-label">Facility</span> <span id="view-client"
                                    class="audit-val"></span></div>
                            <div class="audit-row"><span class="audit-label">Batch Number</span> <span id="view-batch"
                                    class="audit-val"></span></div>
                        </div>

                        <div class="financial-wrap">
                            <div class="audit-row"><span class="audit-label text-slate-500">Base Amount</span> <span
                                    id="view-sub" class="audit-val"></span></div>
                            <div class="audit-row"><span class="audit-label text-slate-500">Output VAT (12%)</span>
                                <span id="view-vat" class="audit-val"></span>
                            </div>
                            <div class="audit-row pt-2 mt-2 border-t border-red-200">
                                <span class="audit-label text-pharma-red">Net Total</span>
                                <span id="view-total" class="text-lg font-black text-slate-800"></span>
                            </div>
                        </div>
                        <button class="btn-audit-print" onclick="window.print()">Print Sales Invoice</button>
                    </div>
                </div>

                <!-- QUICK ENTRY -->
                <div class="quick-entry-card shadow-lg" style="margin-bottom: 15px; margin-top: 20px;">
                    <h3>Quick Sales Entry</h3>

                    <form action="/sales/add" method="POST" class="space-y-4">
                        <div>
                            <label class="entry-label">Target Facility</label>
                            <select name="client" class="input-field-smart font-bold cursor-pointer">
                                <option value="" disabled selected>Choose institutional partner...</option>
                                <% clients.forEach(c => { %>
                                <option value="<%= c.facilityName %>"><%= c.facilityName %></option>
                                <% }) %>
                            </select>
                        </div>

                        <!-- Total Amount -->
                        <div>
                            <label class="entry-label">Contract Value (₱)</label>
                            <input type="number" name="total" step="0.01" required placeholder="0.00"
                                class="input-field-smart font-black text-sm">
                        </div>

                        <!-- Meta Data Grid -->
                        <div class="grid grid-cols-2 gap-3">
                            <div>
                                <label class="entry-label">Payment</label>
                                <select name="payment" class="input-field-smart !text-[10px] font-bold">
                                    <option>Unpaid</option>
                                    <option>Paid</option>
                                </select>
                            </div>
                            <div>
                                <label class="entry-label">Method</label>
                                <select name="method" class="input-field-smart !text-[10px] font-bold">
                                    <option>Cash</option>
                                    <option>Check</option>
                                    <option>Bank</option>
                                </select>
                            </div>
                        </div>

                        <!-- Action Area -->
                        <div class="pt-4">
                            <button type="submit" class="btn-record-sale">
                                Record Transaction
                            </button>
                            <p
                                style="text-align: center; font-size: 8px; color: #cbd5e1; margin-top: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px;">
                                Secured Audit Trail Active
                            </p>
                        </div>
                    </form>
                </div>
            </aside>
        </div>
    </div>

    <!-- HIDDEN FORMAL INVOICE (TIMES NEW ROMAN) -->
    <div id="formal-invoice" style="display:none; padding: 50px; font-family: 'Times New Roman', serif;">
        <div style="text-align: center; border-bottom: 2px solid #000; padding-bottom: 20px; margin-bottom: 30px;">
            <h1 style="margin: 0; font-size: 28px;">ROBIN ROSE TRADING</h1>
            <p style="margin: 5px 0; font-size: 14px;">MEDICAL SUPPLIES & EQUIPMENT DISTRIBUTION</p>
            <p style="margin: 0; font-size: 12px;">VAT REG TIN: 123-456-789-000</p>
        </div>
        <h2 style="text-align: center; text-decoration: underline; font-size: 20px;">SALES INVOICE</h2>
        <div style="display: flex; justify-content: space-between; margin-top: 30px; font-size: 14px;">
            <div><strong>SOLD TO:</strong> <span id="pr-client"></span></div>
            <div><strong>DATE:</strong> <%= new Date().toLocaleDateString() %></div>
        </div>
        <div style="margin-top: 10px; font-size: 14px;"><strong>OR NO:</strong> <span id="pr-id"></span></div>

        <table style="width: 100%; border-collapse: collapse; margin-top: 40px;" border="1">
            <thead>
                <tr style="background: #f0f0f0;">
                    <th style="padding: 10px;">DESCRIPTION</th>
                    <th style="padding: 10px;">AMOUNT</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td style="padding: 15px;">Consolidated Medical Supplies (Institutional Order)</td>
                    <td style="padding: 15px; text-align: right;"><span id="pr-total"></span></td>
                </tr>
            </tbody>
        </table>

        <div style="margin-top: 30px; margin-left: auto; width: 250px; font-size: 14px;">
            <div style="display: flex; justify-content: space-between;"><span>Vatable Sales:</span> <span
                    id="pr-subtotal"></span></div>
            <div style="display: flex; justify-content: space-between;"><span>VAT (12%):</span> <span
                    id="pr-vat"></span></div>
            <div
                style="display: flex; justify-content: space-between; border-top: 1px solid #000; padding-top: 10px; font-weight: bold; font-size: 16px;">
                <span>TOTAL:</span> <span id="pr-total-final"></span>
            </div>
        </div>

        <div style="margin-top: 100px; display: flex; justify-content: space-between; font-size: 12px;">
            <div style="border-top: 1px solid #000; width: 200px; text-align: center; padding-top: 5px;">Authorized
                Signature</div>
            <div style="border-top: 1px solid #000; width: 200px; text-align: center; padding-top: 5px;">Customer
                Acknowledgment</div>
        </div>
    </div>
    </main>

    <script src="/js/sales.js"></script>
    <%- include('../../partials/footer') %>