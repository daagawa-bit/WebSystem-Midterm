<%- include('../../partials/head') %>
    <%- include('../../partials/sidebar') %>

        <div class="main-area">
            <%- include('../../partials/header') %>

                <div class="content p-8">
                    <div class="page-header mb-8">
                        <div>
                            <h1 class="text-3xl font-black text-slate-800 tracking-tight italic">Bulletin <span
                                    class="text-pharma-red">Board</span></h1>
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-[3px]">System-wide
                                notifications & alerts</p>
                        </div>
                        <button class="btn btn-primary shadow-xl" onclick="resetAnnForm()">＋ Post Announcement</button>
                    </div>

                    <!-- KPI Row -->
                    <div class="intel-grid mb-8">
                        <div class="intel-card">
                            <span class="kpi-label-sm">Active Notices</span>
                            <h2>
                                <%= announcements.length %>
                            </h2>
                        </div>
                        <div class="intel-card">
                            <span class="kpi-label-sm">High Priority</span>
                            <h2 class="text-pharma-red">
                                <%= announcements.filter(a=>a.priority==='High').length %>
                            </h2>
                        </div>
                        <div class="intel-card">
                            <span class="kpi-label-sm">Last Update</span>
                            <h2>Today</h2>
                        </div>
                    </div>

                    <div class="grid grid-cols-12 gap-8">

                        <!-- LEFT: ANNOUNCEMENT FEED -->
                        <div class="col-span-7 space-y-4">
                            <h2 class="text-[10px] font-black uppercase text-slate-400 tracking-widest mb-4">Live Feed
                            </h2>

                            <% if (announcements.length> 0) { %>
                                <% announcements.forEach(a=> { %>
                                    <% const priorityColor=(a.priority==='High' ) ? '#ef4444' : (a.priority==='Medium' )
                                        ? '#f59e0b' : '#94a3b8' ; %>
                                        <div class="bg-white p-6 rounded-[2rem] shadow-sm border-l-[6px] transition-all hover:translate-x-2"
                                            style="border-color: '<%= priorityColor %>'">
                                            <div class="flex justify-between items-start mb-3">
                                                <div>
                                                    <h3 class="font-black text-slate-800 text-sm">
                                                        <%= a.title %>
                                                    </h3>
                                                    <p
                                                        class="text-[9px] font-bold text-slate-400 uppercase tracking-tighter mt-1">
                                                        📅 <%= a.date %> | 👥 <%= a.audience %>
                                                    </p>
                                                </div>
                                                <span
                                                    class="px-3 py-1 rounded-full text-[8px] font-black uppercase text-white"
                                                    style="background: '<%= priorityColor %>'">
                                                    <%= a.priority %>
                                                </span>
                                            </div>
                                            <p class="text-xs text-slate-500 leading-relaxed">
                                                <%= a.body %>
                                            </p>

                                            <div class="mt-4 pt-4 border-t border-slate-50 flex gap-4">
                                                <button onclick='editAnnouncement(`<%- JSON.stringify(a) %>`)'
                                                    class="text-[10px] font-black text-slate-400 hover:text-pharma-red uppercase tracking-widest">Edit
                                                    Notice</button>
                                                <a href="/announcement/delete/<%= a.id %>"
                                                    class="text-[10px] font-black text-slate-300 hover:text-red-600 uppercase tracking-widest"
                                                    onclick="return confirm('Archive this notice?')">Archive</a>
                                            </div>
                                        </div>
                                        <% }) %>
                                            <% } else { %>
                                                <div class="bg-white p-20 rounded-[2rem] text-center opacity-30">
                                                    <span class="text-5xl">📭</span>
                                                    <p class="font-bold mt-4">No announcements published.</p>
                                                </div>
                                                <% } %>
                        </div>

                        <!-- RIGHT: POST FORM -->
                        <div class="col-span-5">
                            <div class="form-card bg-white rounded-[2.5rem] p-8 shadow-2xl sticky top-24"
                                id="annFormCard">
                                <div class="flex justify-between items-center mb-6">
                                    <h2 class="text-xl font-black text-slate-800" id="formTitle">📣 Create Notice</h2>
                                    <span id="formModeBadge"
                                        class="px-2 py-1 bg-pharma-red-pale text-pharma-red text-[8px] font-black rounded uppercase italic">New
                                        Post</span>
                                </div>

                                <form method="POST" action="/announcement/add">
                                    <div class="space-y-4">
                                        <div>
                                            <label
                                                class="text-[9px] font-black text-slate-400 uppercase tracking-widest ml-1">Title</label>
                                            <input type="text" name="title" required placeholder="Subject of notice..."
                                                class="w-full mt-1 p-3 bg-slate-50 border-0 rounded-xl outline-none focus:ring-2 focus:ring-pharma-red/20 font-bold text-xs" />
                                        </div>
                                        <div>
                                            <label
                                                class="text-[9px] font-black text-slate-400 uppercase tracking-widest ml-1">Audience</label>
                                            <select name="audience"
                                                class="w-full mt-1 p-3 bg-slate-50 border-0 rounded-xl outline-none text-[11px] font-bold text-slate-500">
                                                <option>All Users</option>
                                                <option>Admin & Staff</option>
                                                <option>Suppliers Only</option>
                                                <option>Clients Only</option>
                                            </select>
                                        </div>
                                        <div>
                                            <label
                                                class="text-[9px] font-black text-slate-400 uppercase tracking-widest ml-1">Priority</label>
                                            <select name="priority"
                                                class="w-full mt-1 p-3 bg-slate-50 border-0 rounded-xl outline-none text-[11px] font-bold text-slate-500">
                                                <option>Low</option>
                                                <option>Medium</option>
                                                <option>High</option>
                                            </select>
                                        </div>
                                        <div>
                                            <label
                                                class="text-[9px] font-black text-slate-400 uppercase tracking-widest ml-1">Message
                                                Content</label>
                                            <textarea name="body" rows="4" required
                                                placeholder="Write the details here..."
                                                class="w-full mt-1 p-4 bg-slate-50 border-0 rounded-2xl outline-none focus:ring-2 focus:ring-pharma-red/20 text-xs font-medium"></textarea>
                                        </div>
                                    </div>

                                    <div class="mt-8 pt-6 border-t border-slate-50">
                                        <button type="submit" id="annSubmitBtn"
                                            class="w-full bg-pharma-red text-white py-4 rounded-xl font-black text-[11px] uppercase tracking-[2px] shadow-lg shadow-pharma-red/20 transition-all hover:scale-[1.02]">
                                            Publish Announcement
                                        </button>
                                        <button type="button" onclick="resetAnnForm()"
                                            class="w-full mt-2 text-[9px] font-bold text-slate-300 uppercase hover:text-slate-500">Clear
                                            Form</button>
                                    </div>
                                </form>
                            </div>
                        </div>

                    </div>
                </div>
                </main>

                <script>
                    function highlightForm() {
                        const card = document.getElementById('annFormCard');
                        card.classList.add('form-focus-pulse');
                        setTimeout(() => card.classList.remove('form-focus-pulse'), 1500);
                    }

                    function editAnnouncement(jsonStr) {
                        const a = JSON.parse(jsonStr);
                        const form = document.querySelector('#annFormCard form');
                        const title = document.getElementById('formTitle');
                        const submitBtn = document.getElementById('annSubmitBtn');
                        const badge = document.getElementById('formModeBadge');

                        form.action = '/announcement/edit/' + a.id;
                        form.querySelector('[name="title"]').value = a.title;
                        form.querySelector('[name="audience"]').value = a.audience;
                        form.querySelector('[name="priority"]').value = a.priority;
                        form.querySelector('[name="body"]').value = a.body;

                        title.innerHTML = "✏️ Edit Notice";
                        badge.innerHTML = "Modification Mode";
                        badge.className = "px-2 py-1 bg-blue-100 text-blue-600 text-[8px] font-black rounded uppercase italic";
                        submitBtn.innerHTML = "Update Announcement";

                        highlightForm();
                    }

                    function resetAnnForm() {
                        const form = document.querySelector('#annFormCard form');
                        const title = document.getElementById('formTitle');
                        const submitBtn = document.getElementById('annSubmitBtn');
                        const badge = document.getElementById('formModeBadge');

                        form.action = '/announcement/add';
                        form.reset();

                        title.innerHTML = "📣 Create Notice";
                        badge.innerHTML = "New Post";
                        badge.className = "px-2 py-1 bg-pharma-red-pale text-pharma-red text-[8px] font-black rounded uppercase italic";
                        submitBtn.innerHTML = "Publish Announcement";

                        highlightForm();
                    }
                </script>

                <%- include('../../partials/footer') %>