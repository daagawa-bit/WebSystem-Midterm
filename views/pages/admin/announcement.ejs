<%- include('../../partials/head') %>
<%- include('../../partials/sidebar') %>

<div class="main-area">
    <%- include('../../partials/header') %>

    <div class="content p-8">
        <div class="page-header mb-8">
            <div>
                <h1 class="text-3xl font-black text-slate-800 tracking-tight italic">Bulletin <span
                        class="text-pharma-red">Board</span></h1>
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-[3px]">System-wide notifications &
                    alerts</p>
            </div>
            <button class="btn btn-primary shadow-xl" onclick="resetAnnForm()">＋ Post Announcement</button>
        </div>

        <!-- KPI Row -->
        <div class="intel-grid mb-8" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;">
            <div class="intel-card">
                <span class="kpi-label-sm">Active Notices</span>
                <h2><%= announcements.length %></h2>
            </div>
            <div class="intel-card">
                <span class="kpi-label-sm">High Priority</span>
                <h2 class="text-pharma-red"><%= announcements.filter(a=>a.priority==='High').length %></h2>
            </div>
            <div class="intel-card">
                <span class="kpi-label-sm">Last Update</span>
                <h2>Today</h2>
            </div>
        </div>

        <div class="bulletin-grid">

            <!-- LEFT: ANNOUNCEMENT FEED (7 Columns) -->
            <div class="col-span-7 space-y-3">
                <h1 class=" mb-14" style="margin-bottom: 10px; font-size: 21px;">Live Broadcast Feed</h1>
                <% if (announcements.length > 0) { %>
                <% announcements.forEach(a => { %>
                <% const priorityColor = (a.priority === 'High') ? '#ef4444' : (a.priority === 'Medium') ? '#f59e0b' : '#94a3b8'; %>

                <div class="notice-card" style=" margin-bottom: 20px; border-left: 4px solid <%= priorityColor %>">
                    <div class="flex justify-between items-start">
                        <div>
                            <div class="flex items-center gap-2 mb-1">
                                <span class="label-micro text-slate-400">📅 <%= a.date %></span>
                                <span class="label-micro text-slate-300">|</span>
                                <span class="label-micro text-slate-400">👥 <%= a.audience %></span>
                            </div>
                            <h3 class="text-notice-title"><%= a.title %></h3>
                        </div>
                        <span class="text-[8px] font-black uppercase px-2 py-1 rounded bg-slate-100 text-slate-500"
                            style="color: <%= priorityColor %>; background: <%= priorityColor %>15">
                            <%= a.priority %>
                        </span>
                    </div>

                    <p class="text-notice-body"><%= a.body %></p>

                    <div class="mt-4 pt-3 border-t border-slate-50 flex gap-4">
                        <button onclick='editAnnouncement(`<%- JSON.stringify(a) %>`)' class="edit-btn">Edit
                            Notice</button>
                        <a href="/announcement/delete/<%= a.id %>" class="action-link"
                            onclick="return confirm('Archive this notice?')">Archive</a>
                    </div>
                </div>
                <% }) %>
                <% } else { %>
                <div class="bg-white p-12 rounded-[2rem] text-center border border-dashed border-slate-200">
                    <p class="label-micro text-slate-300">No Active Announcements</p>
                </div>
                <% } %>
            </div>

            <!-- RIGHT: STICKY FORM (5 Columns) -->
            <div class="col-span-5">
                <div class="form-panel-sticky" id="annFormCard">
                    <div class="flex justify-between items-center mb-6">
                        <div>
                            <h2 class="text-lg font-black text-slate-800" id="formTitle">Create Notice</h2>
                        </div>
                        <span id="formModeBadge"
                            class="px-2 py-1 bg-pharma-red-pale text-pharma-red text-[8px] font-black rounded uppercase italic">New
                            Entry</span>
                    </div>

                    <form method="POST" action="/announcement/add" class="space-y-4">
                        <div>
                            <label class="label-micro ml-1" style="margin-top: 100px;">Subject Title</label>
                            <input type="text" name="title" required placeholder="Header of notice..."
                                class="input-compact" />
                        </div>

                        <div class="grid grid-cols-2 gap-3">
                            <div>
                                <label class="label-micro ml-1">Target Audience</label>
                                <select name="audience" class="input-compact font-bold text-[10px]">
                                    <option>All Users</option>
                                    <option>Admin & Staff</option>
                                    <option>Suppliers Only</option>
                                    <option>Clients Only</option>
                                </select>
                            </div>
                            <div>
                                <label class="label-micro ml-1">Urgency</label>
                                <select name="priority" class="input-compact font-bold text-[10px]">
                                    <option>Low</option>
                                    <option>Medium</option>
                                    <option>High</option>
                                </select>
                            </div>
                        </div>

                        <div>
                            <label class="label-micro ml-1">Message Content</label>
                            <textarea name="body" rows="4" required placeholder="Enter formal announcement details..."
                                class="input-compact font-medium"></textarea>
                        </div>

                        <div class="pt-4 border-top d-flex flex-column gap-2">
                            <button type="submit" id="annSubmitBtn"
                                class="btn btn-danger btn-lg fw-bold text-uppercase w-90 shadow-lg">
                                Publish Broadcast
                            </button>
                            <button type="button" onclick="resetAnnForm()"
                                class="btn btn-outline-danger btn-lg fw-bold text-uppercase w-100">
                                Cancel
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

<%- include('../../partials/footer') %>

<script>
    function highlightForm() {
        const card = document.getElementById('annFormCard');
        card.classList.add('form-focus-pulse');
        setTimeout(() => card.classList.remove('form-focus-pulse'), 1500);
    }

    function editAnnouncement(jsonStr) {
        const a = JSON.parse(jsonStr);
        const form = document.querySelector('#annFormCard form');
        const title = document.getElementById('formTitle');
        const submitBtn = document.getElementById('annSubmitBtn');
        const badge = document.getElementById('formModeBadge');

        form.action = '/announcement/edit/' + a.id;
        form.querySelector('[name="title"]').value = a.title;
        form.querySelector('[name="audience"]').value = a.audience;
        form.querySelector('[name="priority"]').value = a.priority;
        form.querySelector('[name="body"]').value = a.body;

        title.innerHTML = "✏️ Edit Notice";
        badge.innerHTML = "Modification Mode";
        badge.className = "px-2 py-1 bg-blue-100 text-blue-600 text-[8px] font-black rounded uppercase italic";
        submitBtn.innerHTML = "Update Announcement";

        highlightForm();
    }

    function resetAnnForm() {
        const form = document.querySelector('#annFormCard form');
        const title = document.getElementById('formTitle');
        const submitBtn = document.getElementById('annSubmitBtn');
        const badge = document.getElementById('formModeBadge');

        form.action = '/announcement/add';
        form.reset();

        title.innerHTML = "📣 Create Notice";
        badge.innerHTML = "New Post";
        badge.className =
            "px-2 py-1 bg-pharma-red-pale text-pharma-red text-[8px] font-black rounded uppercase italic";
        submitBtn.innerHTML = "Publish Announcement";

        highlightForm();
    }
</script>